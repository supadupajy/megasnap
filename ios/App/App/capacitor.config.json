{
	"appId": "com.chorasnap.chorasnap",
	"appName": "ChoraSnap",
	"webDir": "dist",
	"ios": {
		"allowsLinkPreview": false,
		"scrollEnabled": false,
		"limitsNavigationsToAppBoundDomains": false
	},
	"plugins": {
		"Keyboard": {
			"resize": "body",
			"style": "light",
			"resizeOnFullScreen": true
		},
		"Geolocation": {},
		"StatusBar": {
			"overlaysWebView": false,
			"style": "DARK",
			"backgroundColor": "#FFFFFF"
		}
	},
	"packageClassList": [
		"AppPlugin",
		"CAPCameraPlugin",
		"GeolocationPlugin",
		"PushNotificationsPlugin",
		"StatusBarPlugin"
	]
}
